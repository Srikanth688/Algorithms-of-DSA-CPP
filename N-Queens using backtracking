#include<iostream>
using namespace std;
#define N 5
int board[N][N]={0};
bool issafe(int row,int col)
{
    for(int i=0;i<col;i++)
    {
        if(board[row][i])
        {
            return false;
        }
    }
    for(int i=row,j=col;i>=0&&j>=0;i--,j--)
    {
        if(board[i][j])
        {
            return false;
        }
    }
    for(int i=row,j=col;i<N&&j>=0;i++,j--)
    {
        if(board[i][j])
        {
            return false;
        }
    }
    return true;
}
bool solve(int c)
{
    if(c>=N)
    {
        return true;
    }
    for(int i=0;i<N;i++)
    {
        if(issafe(i,c))
        {
            board[i][c]=1;
            
            if(solve(c+1))
            {
                return true;
            }
            board[i][c]=0;
        }
    }
    return false;
}
int main()
{
    if(solve(0))
    {
        for(int i=0;i<N;i++)
        {
            for(int j=0;j<N;j++)
            {
                cout<<board[i][j]<<" ";
            }
            cout<<endl;
        }
    }
    else{
        cout<<"No Solution";
    }
    return 0;
    
}

#include <iostream>
using namespace std;
void naivestring(string T,string P)
{
    int n=T.length();
    int m=P.length();
    for(int i=0;i<=n-m;i++)
    {
        int j;
        for(j=0;j<m;j++)
        {
            if(T[i+j]!=P[j])
            {
                break;
            }
        }
        if(j==m)
        {
    cout<<"Pattern found at index "<<i<< endl;
        }
    }
}
int main() {
    string T="AABAACAADAABAABA";
    string P="AABA";
    naivestring(T,P);

    return 0;
}

#include <iostream>
using namespace std;
int knapsack(int wt[],int val[],int n,int w)
{
    int dp[100][100];
    for(int i=0;i<=n;i++)
    {
        for(int j=0;j<=w;j++)
        {
            if(i==0||j==0)
            {
                dp[i][j]=0;
            }
        }
    }
    for(int i=1;i<=n;i++)
    {
        for(int j=1;j<=w;j++)
        {
            if(wt[i-1]<=j)
            {
         if(val[i-1]+dp[i-1][j-wt[i-1]]>dp[i-1][w])
                {
                    dp[i][j]=val[i-1]+dp[i-1][j-wt[i-1]];
                    
                }
                else{
                    dp[i][j]=dp[i-1][j];
                }
            }
        }
    }
    return dp[n][w];
}

int main() {
    int wt[] = {1, 3, 4, 5};
    int val[] = {1, 4, 5, 7};
    int n = 4;
    int W = 7;
cout<<"Maximum value:"<<knapsack(wt,val,n,W);

    return 0;
}

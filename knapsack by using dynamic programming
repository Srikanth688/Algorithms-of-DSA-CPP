#include<iostream>
using namespace std;
int main()
{
    int n=4;
    int wt[]={2, 3, 4, 5};
    int val[]={3, 4, 5, 6};
    int W=5;
    int dp[100][100];
    for(int i=0;i<=n;i++)
    {
        for(int j=0;j<=W;j++)
        {
            if(i==0||j==0)
                dp[i][j]=0;
        }
    }
    for(int i=1;i<=n;i++)
    {
        for(int j=1;j<=W;j++)
        {
            if(wt[i-1]<=j)
            {
                dp[i][j]=max(val[i-1]+dp[i-1][j-wt[i-1]],dp[i-1][j]);
            }
            else{
                dp[i][j]=dp[i-1][j];
            }
        }
    }
    cout<<"MAXIMUM CAPACITY:"<<dp[n][W]<<endl;
    return 0;
}

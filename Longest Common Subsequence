#include <iostream>
#include<cstring>
using namespace std;
int lcs(char x[],char y[])
{
    int m=strlen(x);
    int n=strlen(y);
    int dp[100][100];
    
    for(int i=0;i<=m;i++)
    {
        dp[i][0]=0;
    }
    for(int j=0;j<=n;j++)
    {
        dp[0][j]=0;
    }
    for(int i=1;i<=m;i++)
    {
        for(int j=1;j<=n;j++)
        {
            if(x[i-1]==y[j-1])
            {
                dp[i][j]=dp[i-1][j-1]+1;
            }
            else if(dp[i-1][j]>dp[i][j-1])
            {
                dp[i][j]=dp[i-1][j];
            }
            else{
                dp[i][j]=dp[i][j-1];
            }
        }
    }
    return dp[m][n];
    
    
}

int main() {
char x[]="stone";
char y[]="longest";
cout<<"Longest common subsequence:"<<lcs(x,y);

    return 0;
}
